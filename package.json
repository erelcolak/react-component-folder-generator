{
  "name": "react-component-folder-generator",
  "displayName": "React Component Folder with File Tree Generator",
  "description": "Generates a React component folder context menu",
  "icon": "assets/icon.png",
  "keywords": [
    "react",
    "component",
    "folder",
    "file",
    "tree",
    "generator"
  ],
  "publisher": "erelcolak",
  "version": "0.0.2",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "reactComponentGenerator.generate",
        "title": "React Component Folder Generator - New Component"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "when": "explorerResourceIsFolder",
          "command": "reactComponentGenerator.generate",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^18.19.130",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.1.3"
  }
}
